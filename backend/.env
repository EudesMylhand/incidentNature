# ============================================================
#  .env — Variables d'environnement PRODUCTION
#  Copier en .env et remplir, OU configurer directement
#  dans le dashboard Render (Environment Variables)
# ============================================================

# ── Serveur ────────────────────────────────────────────────────
# Render fournit automatiquement sa propre valeur de PORT,
# cette ligne ne sert que pour le développement local.
PORT=3000
NODE_ENV=production

# ── Base de données TiDB Cloud (MySQL compatible) ──────────────
DB_HOST=gateway01.xx-xxxxx.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=xxxxxxxxx.root
DB_PASSWORD=ton_mot_de_passe_tidb
DB_NAME=foretgarde
# IMPORTANT : TiDB Cloud exige une connexion chiffrée
DB_SSL=true

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=remplace_par_une_cle_aleatoire_longue_64_caracteres
JWT_EXPIRES_IN=7d

# ── Code admin ───────────────────────────────────────────────────
ADMIN_SECRET_CODE=FORETGARDE_ADMIN_2026

# ── Frontend (URL Render du site statique) ───────────────────────
FRONTEND_URL=https://foretgarde-frontend.onrender.com

# ── OAuth Google (callback à mettre à jour dans Google Console) ──
GOOGLE_CLIENT_ID=ton_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ton_google_client_secret

# ── OAuth Facebook (callback à mettre à jour dans Meta for Devs) ─
FACEBOOK_APP_ID=ton_facebook_app_id
FACEBOOK_APP_SECRET=ton_facebook_app_secret

# ── Cloudinary — stockage persistant des pièces jointes ──────────
# Crée un compte gratuit sur https://cloudinary.com
# Le Dashboard affiche directement ces 3 valeurs
CLOUDINARY_CLOUD_NAME=ton_cloud_name
CLOUDINARY_API_KEY=ton_api_key
CLOUDINARY_API_SECRET=ton_api_secret

# ── Upload ─────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
